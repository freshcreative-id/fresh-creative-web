# ============================================
# NEXT.JS (frontend) — salin ke .env.local
# ============================================
# D1 / R2 / JWT Worker JANGAN disini; itu di Cloudflare (Wrangler / Dashboard).

# Firebase Auth (clients)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
# Optional:
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=...

# URL aplikasi Next (redirect, link absolut)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Hono di Cloudflare Workers (dev: wrangler biasanya :8787)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Opsional: Redis (hanya jika fitur yang memakai lib/redis.ts aktif)
# REDIS_URL=redis://localhost:6379

# Opsional: debug request timing (lib/api-timing.ts)
# DEBUG_API_TIMING=1

# ============================================
# Backend terpisah: hono-backend/.env.example
# (Wrangler: salin ke .dev.vars — RESEND, XENDIT, REPLICATE, dll.)
# ============================================
